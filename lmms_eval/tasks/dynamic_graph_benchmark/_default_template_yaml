dataset_path: ./dynamic_graph_benchmark_data
dataset_kwargs:
  load_from_disk: True
test_split: test
output_type: generate_until

doc_to_messages: !function utils.dynamic_graph_benchmark_doc_to_messages
doc_to_visual: !function utils.dynamic_graph_benchmark_doc_to_visual
doc_to_text: !function utils.dynamic_graph_benchmark_doc_to_text
doc_to_target: "answer"

generation_kwargs:
  max_new_tokens: 64
  temperature: 0
  top_p: 1.0
  num_beams: 1
  do_sample: false

# Strip <think>...</think> blocks before scoring
reasoning_tags: [["<think>", "</think>"]]

process_results: !function utils.dynamic_graph_benchmark_process_results
metric_list:
  - metric: accuracy
    aggregation: !function utils.dynamic_graph_benchmark_aggregate_results
    higher_is_better: true

metadata:
  - version: 0.0
